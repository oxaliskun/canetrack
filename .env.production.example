# =====================
# CANETRACK PRODUCTION ENV VARIABLES
# =====================
# Use these values when deploying to Render

# Database (Supabase - use Session pooler with ?pgbouncer=true)
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Backend
PORT=5000
FRONTEND_URL="https://canetrack.netlify.app"  # change to your actual Netlify URL

# JWT
JWT_SECRET="change_this_to_a_random_secret_key"
DISCREPANCY_THRESHOLD=50

# For Netlify (Frontend) - set as environment variable in Netlify dashboard
# VITE_API_URL="https://your-backend.onrender.com"
